---
import { CATEGORY_DEFINITIONS, itemsForCategory } from "../lib/categories";
import type { ContentItem } from "../lib/schema";

const { items } = Astro.props as { items: readonly ContentItem[] };
---

<section class="category-links section" data-home-section="categories" aria-labelledby="category-links-title">
  <div class="container">
    <header class="category-links__header">
      <p>探索方向</p>
      <h2 id="category-links-title">按工作目标发现</h2>
    </header>
    <nav class="category-links__grid" aria-label="发现方向">
      {CATEGORY_DEFINITIONS.map((category) => {
        const count = itemsForCategory(items, category.slug).length;
        return (
          <a class="category-link" href={`/category/${category.slug}`} data-accent={category.accent}>
            <span class="category-link__meta">{count} 项</span>
            <h3>{category.track}</h3>
            <p>{category.description}</p>
            <span class="category-link__action" aria-hidden="true">查看方向 <span>→</span></span>
          </a>
        );
      })}
    </nav>
  </div>
</section>

<style>
  .category-links {
    background: var(--mist);
  }

  .category-links__header {
    margin-bottom: 32px;
  }

  .category-links__header p {
    margin-bottom: 10px;
    color: var(--indigo);
    font-size: 14px;
  }

  .category-links__header h2 {
    margin-bottom: 0;
    font-size: 32px;
  }

  .category-links__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border-top: 1px solid var(--frost);
  }

  .category-link {
    min-width: 0;
    padding: 24px;
    border-right: 1px solid var(--frost);
  }

  .category-link:first-child {
    padding-left: 0;
  }

  .category-link:last-child {
    padding-right: 0;
    border-right: 0;
  }

  .category-link:hover h3,
  .category-link:hover .category-link__action {
    color: var(--indigo);
  }

  .category-link__meta {
    display: block;
    margin-bottom: 28px;
    color: var(--slate);
    font-size: 13px;
  }

  .category-link h3 {
    margin-bottom: 10px;
    font-size: 22px;
  }

  .category-link p {
    min-height: 66px;
    margin-bottom: 24px;
    color: var(--steel);
    font-size: 14px;
  }

  .category-link__action {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
  }

  @media (max-width: 960px) {
    .category-links__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .category-link,
    .category-link:first-child,
    .category-link:last-child {
      padding: 24px;
      border-right: 1px solid var(--frost);
      border-bottom: 1px solid var(--frost);
    }

    .category-link:nth-child(2n) {
      border-right: 0;
    }

    .category-link:nth-last-child(-n + 2) {
      border-bottom: 0;
    }
  }

  @media (max-width: 720px) {
    .category-links__header h2 {
      font-size: 26px;
    }

    .category-links__grid {
      grid-template-columns: 1fr;
    }

    .category-link,
    .category-link:first-child,
    .category-link:last-child,
    .category-link:nth-child(2n),
    .category-link:nth-last-child(-n + 2) {
      padding: 22px 0;
      border-right: 0;
      border-bottom: 1px solid var(--frost);
    }

    .category-link:last-child {
      border-bottom: 0;
    }

    .category-link__meta {
      margin-bottom: 14px;
    }

    .category-link p {
      min-height: 0;
    }
  }
</style>
