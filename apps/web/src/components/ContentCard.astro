---
import type { ContentItem } from "../lib/schema";

const { item } = Astro.props as { item: ContentItem };
---

<article class="content-card" data-content-card>
  <a
    class="content-card__inner"
    href={`/content/${item.slug}`}
    data-home-content-link
  >
    <img
      src={item.coverImage}
      alt={`${item.title}内容截图`}
      width="640"
      height="400"
      loading="lazy"
      data-home-content-image
    />
    <div class="content-card__body">
      <div class="content-card__meta">
        <span>{item.category}</span>
        <span class="content-card__network">{item.networkRequirement}</span>
      </div>
      <h3>{item.title}</h3>
      <p>{item.summary}</p>
    </div>
  </a>
</article>

<style>
  .content-card {
    min-width: 0;
  }

  .content-card__inner {
    min-width: 0;
    display: grid;
    grid-template-rows: auto 1fr;
    align-content: start;
  }

  a.content-card__inner:hover h3 {
    color: var(--indigo);
  }

  img {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 10;
    align-self: start;
    display: block;
    border-radius: 4px;
    object-fit: cover;
  }

  .content-card__body {
    padding-top: 16px;
  }

  .content-card__meta {
    min-height: 20px;
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    color: var(--slate);
    font-size: 12px;
  }

  .content-card__meta span {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .content-card__network {
    padding: 3px 7px;
    border: 1px solid var(--frost);
    border-radius: 999px;
    background: var(--mist);
  }

  h3 {
    margin-bottom: 10px;
    font-size: 20px;
  }

  p {
    margin-bottom: 0;
    color: var(--steel);
    font-size: 14px;
  }
</style>
