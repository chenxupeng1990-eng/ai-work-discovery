---
import ContentCard from "./ContentCard.astro";
import type { ContentItem } from "../lib/schema";

const { items, hasMore } = Astro.props as { items: readonly ContentItem[]; hasMore: boolean };
---

<section class="featured section" data-home-section="featured" aria-labelledby="featured-title">
  <div class="container">
    <header class="featured__header">
      <div>
        <p>最新精选</p>
        <h2 id="featured-title">现在值得尝试</h2>
      </div>
      <span>{items.length} 项内容</span>
    </header>
    <div class="featured-grid">
      {items.map((item) => <ContentCard item={item} />)}
    </div>
    {hasMore && <a class="button-secondary featured__more" href="/discover">查看更多</a>}
  </div>
</section>

<style>
  .featured__header {
    margin-bottom: 32px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
  }

  .featured__header p {
    margin-bottom: 10px;
    color: var(--indigo);
    font-size: 14px;
  }

  .featured__header h2 {
    margin-bottom: 0;
    font-size: 32px;
  }

  .featured__header > span {
    flex: 0 0 auto;
    color: var(--slate);
    font-size: 13px;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    align-items: start;
    gap: 40px 24px;
  }

  .featured__more {
    margin-top: 48px;
  }

  @media (max-width: 960px) {
    .featured-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .featured__header h2 {
      font-size: 26px;
    }

    .featured-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
