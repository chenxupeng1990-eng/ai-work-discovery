---
import type { ContentItem } from "../lib/schema";

const { items } = Astro.props as { items: ContentItem[] };
---

<section class="ready section" data-home-section="ready-to-use" aria-labelledby="ready-title">
  <div class="container">
    <div class="ready__heading">
      <p>现在就能用</p>
      <h2 id="ready-title">随手可用</h2>
    </div>
    <div class="ready__grid">
      {items.map((item) => {
        const block = [...item.copyBlocks].sort((left, right) => left.order - right.order)[0];

        return (
          <article class="ready-item" data-ready-item>
            <div class="ready-item__meta">
              <span>{block.type}</span>
              <span>{item.category}</span>
            </div>
            <h3>{block.title}</h3>
            <p>{item.recommendationReason}</p>
            <pre><code>{block.content}</code></pre>
            {item.originalUrl && (
              <a
                href={item.originalUrl}
                target="_blank"
                rel="noreferrer"
                data-home-content-link
              >查看来源</a>
            )}
          </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  .ready__heading {
    margin-bottom: 32px;
  }

  .ready__heading p {
    margin-bottom: 12px;
    color: var(--indigo);
    font-size: 14px;
  }

  h2 {
    margin-bottom: 0;
    font-size: 32px;
  }

  .ready__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
  }

  .ready-item {
    min-width: 0;
    padding: 24px;
    border: 1px solid var(--frost);
    border-radius: 4px;
  }

  .ready-item__meta {
    margin-bottom: 12px;
    display: flex;
    justify-content: space-between;
    gap: 12px;
    color: var(--slate);
    font-size: 12px;
  }

  h3 {
    margin-bottom: 10px;
    font-size: 20px;
  }

  .ready-item p {
    margin-bottom: 18px;
    color: var(--steel);
    font-size: 14px;
  }

  pre {
    min-height: 104px;
    margin: 0 0 18px;
    padding: 14px;
    overflow: auto;
    border-radius: 4px;
    color: var(--ink);
    background: var(--mist);
    font-size: 12px;
    line-height: 1.5;
    white-space: pre-wrap;
    overflow-wrap: anywhere;
  }

  .ready-item a {
    color: var(--indigo);
    font-size: 14px;
  }

  .ready-item a:hover {
    color: var(--indigo-hover);
  }

  @media (max-width: 960px) {
    .ready__grid {
      grid-template-columns: 1fr;
    }

    pre {
      min-height: 0;
    }
  }

  @media (max-width: 720px) {
    h2 {
      font-size: 26px;
    }
  }
</style>
