---
import { CATEGORY_DEFINITIONS } from "../lib/categories";

const feedbackFormUrl = "https://my.feishu.cn/share/base/form/shrcnd0nYB9wha2pnDlUDx3Cief";

const navigation = [
  { label: "Codex 方法", href: "/discover" },
  ...CATEGORY_DEFINITIONS.map((category) => ({
    label: category.track,
    href: `/category/${category.slug}`,
  })),
  { label: "最近更新", href: "/updates" },
];
---

<header class="site-header">
  <div class="header-inner container">
    <a class="brand" href="/" aria-label="QIFEI AI Work Discovery 首页">
      <span class="brand-full">QIFEI AI Work Discovery</span>
    </a>

    <nav class="desktop-navigation" aria-label="主导航">
      {navigation.map((item) => (
        <a class:list={{ "methods-navigation-link": item.href === "/discover" }} href={item.href}>
          {item.label}
        </a>
      ))}
    </nav>

    <div class="header-actions">
      <a class="mobile-discover" href="/discover">Codex 方法</a>
      <a class="icon-button" href="/discover?focus=search" aria-label="搜索 Codex 方法" title="搜索 Codex 方法">
        <span class="search-icon" aria-hidden="true"></span>
      </a>
      <button class="feedback-trigger button-primary" type="button" data-feedback-open>
        想看什么
      </button>

      <div class="mobile-menu">
        <button
          class="icon-button"
          type="button"
          aria-label="打开导航"
          aria-controls="mobile-navigation"
          aria-expanded="false"
          title="打开导航"
          data-mobile-menu-button
        >
          <span class="menu-icon" aria-hidden="true"></span>
        </button>
        <nav id="mobile-navigation" class="mobile-navigation" aria-label="移动端主导航" hidden>
          {navigation.map((item) => <a href={item.href}>{item.label}</a>)}
          <button type="button" data-feedback-open>想看什么</button>
        </nav>
      </div>
    </div>
  </div>
</header>

<dialog class="feedback-dialog" data-feedback-dialog aria-labelledby="feedback-dialog-title">
  <div class="feedback-dialog__header">
    <div>
      <p class="feedback-dialog__eyebrow">内容需求</p>
      <h2 id="feedback-dialog-title">你想看什么？</h2>
      <p>告诉我们你希望解决的问题，后续更新会优先参考真实需求。</p>
    </div>
    <button class="feedback-dialog__close" type="button" aria-label="关闭反馈弹窗" title="关闭" data-feedback-close>
      <span aria-hidden="true">×</span>
    </button>
  </div>
  <div class="feedback-dialog__body">
    <iframe
      title="飞书内容需求反馈表单"
      data-feedback-frame
      data-src={feedbackFormUrl}
      loading="lazy"
      referrerpolicy="strict-origin-when-cross-origin"
    ></iframe>
  </div>
  <div class="feedback-dialog__fallback">
    <span>表单未显示？</span>
    <a href={feedbackFormUrl} target="_blank" rel="noreferrer">在飞书中打开 ↗</a>
  </div>
</dialog>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    height: 48px;
    background: color-mix(in srgb, var(--color-pure-white) 86%, transparent);
    backdrop-filter: saturate(180%) blur(20px);
  }

  .header-inner {
    height: 100%;
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .brand {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-sf-pro-display);
    font-weight: var(--font-weight-semibold);
    white-space: nowrap;
  }

  .mobile-discover {
    display: none;
  }

  .desktop-navigation {
    min-width: 0;
    display: flex;
    align-items: center;
    gap: 18px;
    margin-left: auto;
    color: var(--color-charcoal);
    font-size: 12px;
    font-weight: 400;
    white-space: nowrap;
  }

  .desktop-navigation a:hover,
  .mobile-navigation a:hover {
    color: var(--color-link-blue);
  }

  .desktop-navigation .methods-navigation-link {
    min-height: 30px;
    padding-inline: 10px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid color-mix(in srgb, var(--color-link-blue) 28%, transparent);
    border-radius: var(--radius-button);
    color: var(--color-link-blue);
    background: color-mix(in srgb, var(--color-link-blue) 9%, var(--canvas));
    font-weight: var(--font-weight-medium);
  }

  .desktop-navigation .methods-navigation-link:hover {
    border-color: var(--color-link-blue);
    background: color-mix(in srgb, var(--color-link-blue) 15%, var(--canvas));
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .icon-button {
    width: 36px;
    height: 36px;
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 0;
    border-radius: var(--radius-button);
    color: var(--ink);
    background: var(--canvas);
    cursor: pointer;
  }

  .icon-button:hover {
    color: var(--color-link-blue);
    background: var(--color-ash);
  }

  .feedback-trigger {
    min-height: 36px;
    padding-inline: var(--spacing-16);
    font-size: 14px;
    cursor: pointer;
  }

  .feedback-dialog {
    width: min(760px, calc(100% - 48px));
    height: min(760px, calc(100dvh - 48px));
    max-width: none;
    max-height: none;
    padding: 0;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--color-divider) 82%, transparent);
    border-radius: var(--radius-card);
    color: var(--ink);
    background: color-mix(in srgb, var(--color-pure-white) 94%, transparent);
    backdrop-filter: saturate(180%) blur(24px);
  }

  .feedback-dialog::backdrop {
    background: color-mix(in srgb, var(--color-apple-ink) 34%, transparent);
    backdrop-filter: blur(8px);
  }

  .feedback-dialog[open] {
    display: grid;
    grid-template-rows: auto minmax(0, 1fr) auto;
  }

  .feedback-dialog__header {
    padding: var(--spacing-24);
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--spacing-24);
    border-bottom: 1px solid var(--color-divider);
  }

  .feedback-dialog__eyebrow {
    margin-bottom: var(--spacing-8);
    color: var(--color-link-blue);
    font-size: var(--text-caption);
    font-weight: var(--font-weight-semibold);
  }

  .feedback-dialog h2 {
    margin-bottom: var(--spacing-8);
    font-size: 28px;
    line-height: 1.18;
  }

  .feedback-dialog__header p:last-child {
    max-width: 520px;
    margin-bottom: 0;
    color: var(--color-graphite);
    font-size: 14px;
    line-height: 1.55;
  }

  .feedback-dialog__close {
    flex: 0 0 auto;
    width: 36px;
    height: 36px;
    padding: 0;
    display: grid;
    place-items: center;
    border: 1px solid var(--color-divider);
    border-radius: 50%;
    color: var(--ink);
    background: color-mix(in srgb, var(--color-pure-white) 78%, transparent);
    font-size: 24px;
    line-height: 1;
    cursor: pointer;
  }

  .feedback-dialog__close:hover {
    color: var(--color-pure-white);
    border-color: var(--color-apple-ink);
    background: var(--color-apple-ink);
  }

  .feedback-dialog__body {
    min-height: 0;
    background: var(--color-fog-canvas);
  }

  .feedback-dialog__body iframe {
    width: 100%;
    height: 100%;
    display: block;
    border: 0;
    background: var(--color-pure-white);
  }

  .feedback-dialog__fallback {
    min-height: 48px;
    padding-inline: var(--spacing-24);
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: var(--spacing-8);
    border-top: 1px solid var(--color-divider);
    color: var(--color-graphite);
    font-size: 13px;
  }

  .feedback-dialog__fallback a {
    color: var(--color-link-blue);
  }

  .search-icon {
    position: relative;
    width: 16px;
    height: 16px;
    border: 1.5px solid currentColor;
    border-radius: 50%;
  }

  .search-icon::after {
    position: absolute;
    right: -5px;
    bottom: -3px;
    width: 7px;
    height: 1.5px;
    background: currentColor;
    content: "";
    transform: rotate(45deg);
    transform-origin: left center;
  }

  .mobile-menu {
    position: relative;
    display: none;
  }

  .menu-icon,
  .menu-icon::before,
  .menu-icon::after {
    width: 18px;
    height: 1.5px;
    display: block;
    background: currentColor;
  }

  .menu-icon {
    position: relative;
  }

  .menu-icon::before,
  .menu-icon::after {
    position: absolute;
    left: 0;
    content: "";
  }

  .menu-icon::before {
    top: -6px;
  }

  .menu-icon::after {
    top: 6px;
  }

  .mobile-navigation {
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    width: min(280px, calc(100vw - 32px));
    padding: var(--spacing-8);
    display: grid;
    border: 0;
    border-radius: var(--radius-card);
    background: var(--canvas);
  }

  .mobile-navigation[hidden] {
    display: none;
  }

  .mobile-navigation a {
    min-height: 44px;
    padding: 0 12px;
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--frost);
    color: var(--steel);
    font-size: 14px;
  }

  .mobile-navigation button {
    min-height: 44px;
    padding: 0 12px;
    border: 0;
    color: var(--color-link-blue);
    background: transparent;
    text-align: left;
    cursor: pointer;
  }

  .mobile-navigation a:last-child {
    border-bottom: 0;
  }

  @media (max-width: 1120px) {
    .desktop-navigation {
      display: none;
    }

    .header-actions {
      margin-left: auto;
    }

    .mobile-discover {
      min-height: 34px;
      padding-inline: 12px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border: 1px solid color-mix(in srgb, var(--color-link-blue) 28%, transparent);
      border-radius: var(--radius-button);
      color: var(--color-link-blue);
      background: color-mix(in srgb, var(--color-link-blue) 9%, var(--canvas));
      font-size: 14px;
      font-weight: var(--font-weight-medium);
      white-space: nowrap;
      transition: background-color 160ms ease, border-color 160ms ease;
    }

    .mobile-discover:hover {
      border-color: var(--color-link-blue);
      background: color-mix(in srgb, var(--color-link-blue) 15%, var(--canvas));
    }

    .mobile-discover:focus-visible {
      outline: 2px solid var(--color-link-blue);
      outline-offset: 2px;
    }

    .mobile-menu {
      display: block;
    }
  }

  @media (max-width: 720px) {
    .site-header {
      height: 56px;
    }

    .header-inner {
      gap: 8px;
    }

    .mobile-discover {
      display: none;
    }

    .brand-full {
      font-size: 14px;
    }

    .feedback-trigger {
      min-height: 36px;
      padding-inline: 12px;
      font-size: 14px;
    }

    .icon-button {
      width: 36px;
      height: 36px;
    }
  }

  @media (max-width: 390px) {
    .mobile-discover {
      display: none;
    }

    .feedback-trigger {
      padding-inline: 8px;
    }
  }

  @media (max-width: 360px) {
    .feedback-trigger {
      display: none;
    }
  }

  @media (max-width: 720px) {
    .feedback-dialog {
      width: calc(100% - 24px);
      height: calc(100dvh - 24px);
      border-radius: 20px;
    }

    .feedback-dialog__header {
      padding: var(--spacing-20);
      gap: var(--spacing-16);
    }

    .feedback-dialog h2 {
      font-size: 24px;
    }

    .feedback-dialog__fallback {
      padding-inline: var(--spacing-20);
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .feedback-dialog[open] {
      animation: feedback-dialog-in 180ms var(--motion-apple);
    }
  }

  @keyframes feedback-dialog-in {
    from {
      opacity: 0;
      transform: translateY(12px) scale(0.985);
    }
  }
</style>

<script is:inline>
  const menuButton = document.querySelector("[data-mobile-menu-button]");
  const mobileNavigation = document.querySelector("#mobile-navigation");
  const feedbackDialog = document.querySelector("[data-feedback-dialog]");
  const feedbackFrame = document.querySelector("[data-feedback-frame]");
  const feedbackOpenButtons = document.querySelectorAll("[data-feedback-open]");
  const feedbackCloseButton = document.querySelector("[data-feedback-close]");
  let feedbackInvoker = null;

  const setMenuExpanded = (expanded) => {
    menuButton?.setAttribute("aria-expanded", String(expanded));
    menuButton?.setAttribute("aria-label", expanded ? "关闭导航" : "打开导航");
    menuButton?.setAttribute("title", expanded ? "关闭导航" : "打开导航");
    mobileNavigation?.toggleAttribute("hidden", !expanded);
  };

  menuButton?.addEventListener("click", () => {
    setMenuExpanded(menuButton.getAttribute("aria-expanded") !== "true");
  });

  feedbackOpenButtons.forEach((button) => {
    button.addEventListener("click", () => {
      if (!feedbackDialog) return;
      feedbackInvoker = button;
      if (!feedbackFrame?.src) {
        const source = feedbackFrame?.dataset.src;
        if (feedbackFrame && source) feedbackFrame.src = source;
      }
      setMenuExpanded(false);
      feedbackDialog.showModal();
      feedbackCloseButton?.focus();
    });
  });

  feedbackCloseButton?.addEventListener("click", () => feedbackDialog?.close());

  feedbackDialog?.addEventListener("click", (event) => {
    if (event.target === feedbackDialog) feedbackDialog.close();
  });

  feedbackDialog?.addEventListener("close", () => {
    feedbackInvoker?.focus();
    feedbackInvoker = null;
  });

  document.addEventListener("keydown", (event) => {
    if (event.key !== "Escape" || menuButton?.getAttribute("aria-expanded") !== "true") return;
    setMenuExpanded(false);
    menuButton.focus();
  });
</script>
