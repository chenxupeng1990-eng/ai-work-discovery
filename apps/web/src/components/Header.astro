---
import { CATEGORY_DEFINITIONS } from "../lib/categories";

const navigation = [
  { label: "发现", href: "/discover" },
  ...CATEGORY_DEFINITIONS.map((category) => ({
    label: category.track,
    href: `/category/${category.slug}`,
  })),
  { label: "最近更新", href: "/updates" },
];
---

<header class="site-header">
  <div class="header-inner container">
    <a class="brand" href="/" aria-label="QIFEI AI Work Discovery 首页">
      <span class="brand-full">QIFEI AI Work Discovery</span>
    </a>

    <nav class="desktop-navigation" aria-label="主导航">
      {navigation.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>

    <div class="header-actions">
      <a class="mobile-discover" href="/discover">发现</a>
      <a class="icon-button" href="/discover" aria-label="搜索" title="搜索">
        <span class="search-icon" aria-hidden="true"></span>
      </a>
      <button class="submit-link button-primary" type="button" aria-disabled="true" title="提交入口即将开放">
        提交内容
      </button>

      <div class="mobile-menu">
        <button
          class="icon-button"
          type="button"
          aria-label="打开导航"
          aria-controls="mobile-navigation"
          aria-expanded="false"
          title="打开导航"
          data-mobile-menu-button
        >
          <span class="menu-icon" aria-hidden="true"></span>
        </button>
        <nav id="mobile-navigation" class="mobile-navigation" aria-label="移动端主导航" hidden>
          {navigation.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>
      </div>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    height: 48px;
    background: color-mix(in srgb, var(--color-pure-white) 86%, transparent);
    backdrop-filter: saturate(180%) blur(20px);
  }

  .header-inner {
    height: 100%;
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .brand {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-sf-pro-display);
    font-weight: var(--font-weight-semibold);
    white-space: nowrap;
  }

  .mobile-discover {
    display: none;
  }

  .desktop-navigation {
    min-width: 0;
    display: flex;
    align-items: center;
    gap: 18px;
    margin-left: auto;
    color: var(--color-charcoal);
    font-size: 12px;
    font-weight: 400;
    white-space: nowrap;
  }

  .desktop-navigation a:hover,
  .mobile-navigation a:hover {
    color: var(--color-link-blue);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .icon-button {
    width: 36px;
    height: 36px;
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 0;
    border-radius: var(--radius-button);
    color: var(--ink);
    background: var(--canvas);
    cursor: pointer;
  }

  .icon-button:hover {
    color: var(--color-link-blue);
    background: var(--color-ash);
  }

  .submit-link {
    min-height: 36px;
    padding-inline: var(--spacing-16);
    font-size: 14px;
  }

  .submit-link[aria-disabled="true"] {
    cursor: not-allowed;
  }

  .search-icon {
    position: relative;
    width: 16px;
    height: 16px;
    border: 1.5px solid currentColor;
    border-radius: 50%;
  }

  .search-icon::after {
    position: absolute;
    right: -5px;
    bottom: -3px;
    width: 7px;
    height: 1.5px;
    background: currentColor;
    content: "";
    transform: rotate(45deg);
    transform-origin: left center;
  }

  .mobile-menu {
    position: relative;
    display: none;
  }

  .menu-icon,
  .menu-icon::before,
  .menu-icon::after {
    width: 18px;
    height: 1.5px;
    display: block;
    background: currentColor;
  }

  .menu-icon {
    position: relative;
  }

  .menu-icon::before,
  .menu-icon::after {
    position: absolute;
    left: 0;
    content: "";
  }

  .menu-icon::before {
    top: -6px;
  }

  .menu-icon::after {
    top: 6px;
  }

  .mobile-navigation {
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    width: min(280px, calc(100vw - 32px));
    padding: var(--spacing-8);
    display: grid;
    border: 0;
    border-radius: var(--radius-card);
    background: var(--canvas);
  }

  .mobile-navigation[hidden] {
    display: none;
  }

  .mobile-navigation a {
    min-height: 44px;
    padding: 0 12px;
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--frost);
    color: var(--steel);
    font-size: 14px;
  }

  .mobile-navigation a:last-child {
    border-bottom: 0;
  }

  @media (max-width: 1120px) {
    .desktop-navigation {
      display: none;
    }

    .header-actions {
      margin-left: auto;
    }

    .mobile-discover {
      display: inline-flex;
      align-items: center;
      color: var(--steel);
      font-size: 14px;
    }

    .mobile-menu {
      display: block;
    }
  }

  @media (max-width: 720px) {
    .site-header {
      height: 56px;
    }

    .header-inner {
      gap: 8px;
    }

    .brand-full {
      font-size: 14px;
    }

    .submit-link {
      min-height: 36px;
      padding-inline: 12px;
      font-size: 14px;
    }

    .icon-button {
      width: 36px;
      height: 36px;
    }
  }

  @media (max-width: 390px) {
    .mobile-discover {
      display: none;
    }

    .submit-link {
      padding-inline: 8px;
    }
  }

  @media (max-width: 360px) {
    .submit-link {
      display: none;
    }
  }
</style>

<script>
  const menuButton = document.querySelector<HTMLButtonElement>("[data-mobile-menu-button]");
  const mobileNavigation = document.querySelector<HTMLElement>("#mobile-navigation");

  const setMenuExpanded = (expanded: boolean) => {
    menuButton?.setAttribute("aria-expanded", String(expanded));
    menuButton?.setAttribute("aria-label", expanded ? "关闭导航" : "打开导航");
    menuButton?.setAttribute("title", expanded ? "关闭导航" : "打开导航");
    mobileNavigation?.toggleAttribute("hidden", !expanded);
  };

  menuButton?.addEventListener("click", () => {
    setMenuExpanded(menuButton.getAttribute("aria-expanded") !== "true");
  });

  document.addEventListener("keydown", (event) => {
    if (event.key !== "Escape" || menuButton?.getAttribute("aria-expanded") !== "true") return;
    setMenuExpanded(false);
    menuButton.focus();
  });
</script>
