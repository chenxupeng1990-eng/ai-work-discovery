---
import { DiscoveryExplorer } from "../components/DiscoveryExplorer";
import { HeroCarousel } from "../components/HeroCarousel";
import { QuickMatch } from "../components/QuickMatch";
import BaseLayout from "../layouts/BaseLayout.astro";
import { selectHeroItems } from "../lib/home-content";
import { publicDataset } from "../lib/public-dataset";

const items = publicDataset.items;
const heroItems = selectHeroItems(items);
---

<BaseLayout
  title="QIFEI AI 工作灵感与实践 | QIFEI AI Work Discovery"
  description="发现可直接应用于工作的 AI 灵感、协作方式、案例与工具。"
>
  {heroItems.length > 0
    ? <HeroCarousel items={heroItems} client:load />
    : (
      <section class="home-empty" data-home-empty="true">
        <h1>QIFEI AI Work Discovery</h1>
        <p>暂无已发布内容</p>
      </section>
    )}
  <QuickMatch items={items} client:load />
  <section class="home-discovery" data-home-section="discovery">
    <div class="container">
      <DiscoveryExplorer items={items} limit={18} showMoreLink client:load />
    </div>
  </section>
</BaseLayout>

<style>
  .home-empty {
    min-height: 500px;
    padding: 80px 24px;
    display: grid;
    place-content: center;
    text-align: center;
    background: var(--mist);
  }

  .home-empty h1 {
    margin-bottom: 12px;
    font-size: 48px;
  }

  .home-empty p {
    margin-bottom: 0;
    color: var(--steel);
  }

  .home-discovery {
    padding-block: var(--spacing-32) var(--spacing-100);
    background: var(--color-pure-white);
  }

  @media (max-width: 720px) {
    .home-empty h1 {
      font-size: 36px;
    }

    .home-discovery {
      padding-block: var(--spacing-24) var(--spacing-80);
    }
  }
</style>
