---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="AI Work Discovery"
  description="发现可直接应用于工作的 AI 灵感、协作方式、案例与工具。"
>
  <section class="home-intro">
    <div class="container intro-content">
      <p class="eyebrow">AI 工作发现</p>
      <h1>发现值得带回工作的 AI 实践</h1>
      <p class="intro-copy">精选灵感、协作方式、实践案例与可复用工具，帮助团队更快找到下一步。</p>
    </div>
  </section>
</BaseLayout>

<style>
  .home-intro {
    min-height: 520px;
    display: flex;
    align-items: center;
    background: var(--canvas);
  }

  .intro-content {
    padding-block: 72px;
  }

  .eyebrow {
    margin-bottom: 16px;
    color: var(--indigo);
    font-size: 14px;
    font-weight: 400;
  }

  h1 {
    max-width: 760px;
    margin-bottom: 24px;
    font-size: 48px;
  }

  .intro-copy {
    max-width: 680px;
    margin-bottom: 32px;
    color: var(--steel);
    font-size: 18px;
  }

  @media (max-width: 720px) {
    .home-intro {
      min-height: 440px;
    }

    .intro-content {
      padding-block: 56px;
    }

    h1 {
      font-size: 36px;
    }

    .intro-copy {
      font-size: 16px;
    }
  }
</style>
