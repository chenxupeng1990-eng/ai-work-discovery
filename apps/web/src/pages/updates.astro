---
import BaseLayout from "../layouts/BaseLayout.astro";
import { publicDataset } from "../lib/public-dataset";
import type { ContentItem } from "../lib/schema";

const items = [...publicDataset.items].sort((left, right) =>
  Date.parse(right.updatedAt) - Date.parse(left.updatedAt) || left.slug.localeCompare(right.slug),
);
const groups = items.reduce<Array<{ date: string; items: ContentItem[] }>>((result, item) => {
  const date = item.updatedAt.slice(0, 10);
  const current = result.at(-1);

  if (current?.date === date) current.items.push(item);
  else result.push({ date, items: [item] });

  return result;
}, []);
---

<BaseLayout title="最近更新 | QIFEI AI Work Discovery" description="按更新时间查看 AI Work Discovery 的最新内容。">
  <header class="updates-hero">
    <div class="container">
      <p>持续维护</p>
      <h1>最近更新</h1>
    </div>
  </header>

  <div class="container updates-list">
    {groups.map((group) => (
      <section class="update-group" data-update-group data-date={group.date} aria-labelledby={`updates-${group.date}`}>
        <h2 id={`updates-${group.date}`}><time datetime={group.date}>{group.date}</time></h2>
        <div>
          {group.items.map((item) => (
            <article class="update-item" data-update-item>
              <div>
                <span>{item.category}</span>
                <span>{item.type}</span>
              </div>
              <h3><a href={`/content/${item.slug}`}>{item.title}</a></h3>
              <p>{item.summary}</p>
            </article>
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>

<style>
  .updates-hero {
    padding-block: 56px;
    border-bottom: 1px solid var(--frost);
    background: var(--mist);
  }

  .updates-hero p {
    margin-bottom: 10px;
    color: var(--indigo);
    font-size: 13px;
  }

  h1 {
    margin-bottom: 0;
    font-size: 48px;
  }

  .updates-list {
    padding-block: 64px 80px;
  }

  .update-group {
    display: grid;
    grid-template-columns: minmax(120px, 0.32fr) minmax(0, 1fr);
    gap: 48px;
    padding-block: 36px;
    border-top: 1px solid var(--frost);
  }

  .update-group:first-child {
    padding-top: 0;
    border-top: 0;
  }

  .update-group h2 {
    margin: 0;
    color: var(--slate);
    font-size: 16px;
  }

  .update-item {
    min-width: 0;
    padding-block: 24px;
    border-top: 1px solid var(--frost);
  }

  .update-item:first-child {
    padding-top: 0;
    border-top: 0;
  }

  .update-item > div {
    margin-bottom: 8px;
    display: flex;
    gap: 16px;
    color: var(--slate);
    font-size: 12px;
  }

  .update-item h3 {
    margin-bottom: 8px;
    overflow-wrap: anywhere;
    font-size: 22px;
  }

  .update-item a:hover {
    color: var(--indigo);
  }

  .update-item p {
    margin-bottom: 0;
    color: var(--steel);
  }

  @media (max-width: 720px) {
    .updates-hero {
      padding-block: 40px;
    }

    h1 {
      font-size: 36px;
    }

    .updates-list {
      padding-block: 48px 56px;
    }

    .update-group {
      grid-template-columns: 1fr;
      gap: 20px;
      padding-block: 32px;
    }
  }
</style>
