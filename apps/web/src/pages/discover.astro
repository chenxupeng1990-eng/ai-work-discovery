---
import { CodexMethodsExplorer } from "../components/CodexMethodsExplorer";
import BaseLayout from "../layouts/BaseLayout.astro";
import { codexMethods } from "../data/codex-methods";

const lastVerified = [...codexMethods]
  .map(({ verifiedAt }) => verifiedAt)
  .sort((left, right) => right.localeCompare(left))[0];
---

<BaseLayout
  title="Codex 方法合集 | QIFEI AI Work Discovery"
  description="经过验证、可以直接复制执行的 Codex 工作方法合集"
>
  <section class="methods-hero" aria-labelledby="methods-title">
    <div class="methods-hero__inner container">
      <div>
        <p class="methods-hero__eyebrow">CODEX METHODS</p>
        <h1 id="methods-title">Codex 方法合集</h1>
        <p class="methods-hero__summary">
          找到一个工作问题，复制方法，让 Codex 先完成可验证的草稿
        </p>
      </div>
      <dl class="methods-hero__stats" aria-label="方法库状态">
        <div>
          <dt>当前收录</dt>
          <dd>{codexMethods.length} 个方法</dd>
        </div>
        <div>
          <dt>验证日期</dt>
          <dd>{lastVerified}</dd>
        </div>
        <div>
          <dt>更新节奏</dt>
          <dd>每周人工复核</dd>
        </div>
      </dl>
    </div>
  </section>

  <div class="methods-content container">
    <CodexMethodsExplorer methods={codexMethods} client:load />
  </div>

  <section class="methods-policy">
    <div class="container methods-policy__grid">
      <article>
        <span>安全边界</span>
        <h2>关键动作必须停下来确认</h2>
        <p>删除、发送、付款、发布、权限修改和结束进程前，Codex 必须展示影响并等待确认</p>
      </article>
      <article>
        <span>收录标准</span>
        <h2>解决明确问题，而不是堆链接</h2>
        <p>每个方法都要有可复制提示词、能力依据、风险说明和最近验证日期</p>
      </article>
      <article>
        <span>每周更新</span>
        <h2>过时方法直接停止展示</h2>
        <p>每周检查来源、Codex 当前能力和提示词边界，验证失败的方法转为停用状态</p>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .methods-hero {
    border-bottom: 1px solid var(--color-divider);
    background: var(--color-fog-canvas);
  }

  .methods-hero__inner {
    min-height: 320px;
    padding-block: var(--spacing-76);
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
    gap: var(--spacing-56);
  }

  .methods-hero__eyebrow {
    margin-bottom: var(--spacing-12);
    color: var(--color-link-blue);
    font-size: var(--text-caption);
    font-weight: var(--font-weight-semibold);
  }

  .methods-hero h1 {
    margin-bottom: var(--spacing-16);
    font-size: clamp(46px, 6vw, 72px);
    font-weight: var(--font-weight-medium);
    line-height: 1.05;
  }

  .methods-hero__summary {
    max-width: 680px;
    margin-bottom: 0;
    color: var(--color-graphite);
    font-size: var(--text-body);
    line-height: var(--leading-body);
  }

  .methods-hero__stats {
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(130px, 1fr));
    border-top: 1px solid var(--color-divider);
    border-bottom: 1px solid var(--color-divider);
  }

  .methods-hero__stats > div {
    padding: var(--spacing-16);
    border-right: 1px solid var(--color-divider);
  }

  .methods-hero__stats > div:last-child {
    border-right: 0;
  }

  .methods-hero__stats dt {
    margin-bottom: var(--spacing-8);
    color: var(--color-graphite);
    font-size: var(--text-caption);
  }

  .methods-hero__stats dd {
    margin: 0;
    font-size: 15px;
    font-weight: var(--font-weight-medium);
    white-space: nowrap;
  }

  .methods-policy {
    padding-block: var(--spacing-80);
    border-top: 1px solid var(--color-divider);
    background: var(--color-fog-canvas);
  }

  .methods-policy__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .methods-policy article {
    min-width: 0;
    padding-inline: var(--spacing-28);
    border-right: 1px solid var(--color-divider);
  }

  .methods-policy article:first-child {
    padding-left: 0;
  }

  .methods-policy article:last-child {
    padding-right: 0;
    border-right: 0;
  }

  .methods-policy span {
    color: var(--color-link-blue);
    font-size: var(--text-caption);
    font-weight: var(--font-weight-semibold);
  }

  .methods-policy h2 {
    margin: var(--spacing-12) 0;
    font-size: 22px;
    font-weight: var(--font-weight-medium);
  }

  .methods-policy p {
    margin-bottom: 0;
    color: var(--color-graphite);
    font-size: 15px;
    line-height: 1.55;
  }

  @media (max-width: 960px) {
    .methods-hero__inner {
      grid-template-columns: 1fr;
      align-items: start;
      gap: var(--spacing-40);
    }

    .methods-hero__stats {
      width: 100%;
    }
  }

  @media (max-width: 720px) {
    .methods-hero__inner {
      min-height: 0;
      padding-block: var(--spacing-48);
      gap: var(--spacing-28);
    }

    .methods-hero h1 {
      font-size: 42px;
    }

    .methods-hero__summary {
      font-size: 17px;
    }

    .methods-hero__stats {
      grid-template-columns: 1fr;
    }

    .methods-hero__stats > div {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--spacing-16);
      border-right: 0;
      border-bottom: 1px solid var(--color-divider);
    }

    .methods-hero__stats > div:last-child {
      border-bottom: 0;
    }

    .methods-hero__stats dt {
      margin-bottom: 0;
    }

    .methods-policy__grid {
      grid-template-columns: 1fr;
    }

    .methods-policy article,
    .methods-policy article:first-child,
    .methods-policy article:last-child {
      padding: var(--spacing-24) 0;
      border-right: 0;
      border-bottom: 1px solid var(--color-divider);
    }

    .methods-policy article:last-child {
      border-bottom: 0;
    }
  }
</style>
