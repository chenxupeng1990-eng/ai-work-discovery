---
import { DiscoveryExplorer } from "../components/DiscoveryExplorer";
import BaseLayout from "../layouts/BaseLayout.astro";
import { publicDataset } from "../lib/public-dataset";

const { items } = publicDataset;
const featuredItem = items.find((item) => item.featured) ?? items[0];
---

<BaseLayout
  title="发现 | QIFEI AI Work Discovery"
  description="发现 AI 工作灵感、协作方式、案例和工具。"
>
  <section class="discover-hero" aria-labelledby="discover-title">
    <div class="discover-hero__inner container">
      <div class="discover-hero__copy">
        <p class="discover-hero__eyebrow">工作发现</p>
        <h1 id="discover-title"><span>找到下一项值得尝试的</span><br /><span>AI 工作方法</span></h1>
        <p class="discover-hero__summary">
          探索真实可复用的实践，快速应用到你的团队与工作流。
        </p>
        <div class="discover-hero__actions">
          <a class="button-primary" href={`/content/${featuredItem.slug}`}>浏览本周精选</a>
          <a class="discover-hero__link" href="/discover#discovery-results-title">查看全部</a>
        </div>
      </div>

      <div class="spotlight" aria-label="本周精选内容">
        <a class="spotlight__visual" href={`/content/${featuredItem.slug}`}>
          <img
            src={featuredItem.coverImage}
            alt={`${featuredItem.title}内容预览`}
            width="960"
            height="600"
            fetchpriority="high"
          />
        </a>
        <div class="spotlight__copy">
          <p>本周精选</p>
          <h2>{featuredItem.title.replace(/^用飞书桥/, "")}</h2>
          <a href={`/content/${featuredItem.slug}`}>阅读内容</a>
        </div>
      </div>
    </div>
  </section>

  <div class="discover-content">
    <div class="container">
      <DiscoveryExplorer client:load items={items} />
    </div>
  </div>
</BaseLayout>

<style>
  .discover-hero {
    min-height: 620px;
    overflow: hidden;
    background-color: var(--color-fog-canvas);
    background-image: url("/images/hero-glass-rings.webp");
    background-position: center;
    background-size: cover;
  }

  .discover-hero__inner {
    min-height: 620px;
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    align-items: center;
    gap: var(--spacing-40);
  }

  .discover-hero__copy {
    position: relative;
    z-index: 2;
    align-self: center;
    padding-block: var(--spacing-80);
  }

  .discover-hero__eyebrow {
    margin-bottom: var(--spacing-24);
    color: var(--color-graphite);
    font-size: var(--text-body-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--tracking-body-sm);
  }

  .discover-hero h1 {
    max-width: 620px;
    margin-bottom: var(--spacing-24);
    color: var(--color-apple-ink);
    font-size: clamp(52px, 4vw, 64px);
    font-weight: var(--font-weight-semibold);
    line-height: var(--leading-heading);
    letter-spacing: var(--tracking-heading-lg);
  }

  .discover-hero__summary {
    max-width: 500px;
    margin-bottom: var(--spacing-32);
    color: var(--color-graphite);
    font-size: var(--text-body);
    line-height: var(--leading-body);
    letter-spacing: var(--tracking-body);
  }

  .discover-hero__actions {
    display: flex;
    align-items: center;
    gap: var(--spacing-28);
  }

  .discover-hero__actions .button-primary {
    min-height: 48px;
    padding-inline: var(--spacing-24);
    font-size: var(--text-body-sm);
  }

  .discover-hero__link,
  .spotlight__copy a {
    color: var(--color-link-blue);
    font-size: var(--text-body-sm);
  }

  .discover-hero__link:hover,
  .spotlight__copy a:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .spotlight {
    position: relative;
    min-width: 0;
    min-height: 520px;
    display: flex;
    align-items: center;
  }

  .spotlight__visual {
    width: min(70%, 760px);
    min-width: 0;
    display: block;
    transform: translateX(2%);
    transition: transform 350ms ease;
  }

  .spotlight__visual:hover {
    transform: translateX(2%) scale(1.012);
  }

  .spotlight__visual img {
    width: 100%;
    height: auto;
    max-width: 100%;
    aspect-ratio: 16 / 10;
    display: block;
    border-radius: var(--radius-image);
    object-fit: cover;
    object-position: top;
  }

  .spotlight__copy {
    position: absolute;
    right: 0;
    bottom: var(--spacing-48);
    width: min(240px, 24%);
  }

  .spotlight__copy p {
    margin-bottom: var(--spacing-12);
    color: var(--color-graphite);
    font-size: var(--text-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--tracking-caption);
  }

  .spotlight__copy h2 {
    margin-bottom: var(--spacing-16);
    color: var(--color-apple-ink);
    font-size: var(--text-subheading);
    line-height: var(--leading-subheading);
    letter-spacing: var(--tracking-subheading);
  }

  .discover-content {
    padding-block: var(--spacing-32) var(--spacing-100);
    background: var(--color-pure-white);
  }

  :global(.discovery-explorer) {
    min-width: 0;
  }

  :global(.discovery-controls) {
    min-width: 0;
    min-height: 124px;
    display: grid;
    align-content: start;
    gap: var(--spacing-16);
  }

  :global(.discovery-search) {
    position: relative;
    display: block;
  }

  :global(.discovery-search input) {
    width: 100%;
    min-height: 52px;
    padding: 0 var(--spacing-20) 0 var(--spacing-48);
    border: 0;
    border-radius: var(--radius-button);
    color: var(--color-apple-ink);
    background: var(--color-fog-canvas);
    font-size: var(--text-body-sm);
  }

  :global(.discovery-search input::placeholder) {
    color: var(--color-slate);
  }

  :global(.discovery-search__icon) {
    position: absolute;
    top: 50%;
    left: var(--spacing-20);
    z-index: 1;
    width: 14px;
    height: 14px;
    border: 1.5px solid var(--color-graphite);
    border-radius: 50%;
    pointer-events: none;
    transform: translateY(-55%);
  }

  :global(.discovery-search__icon::after) {
    position: absolute;
    right: -5px;
    bottom: -3px;
    width: 6px;
    height: 1.5px;
    background: var(--color-graphite);
    content: "";
    transform: rotate(45deg);
    transform-origin: left center;
  }

  :global(.discovery-filter-row) {
    min-width: 0;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: var(--spacing-24);
  }

  :global(.discovery-categories) {
    min-width: 0;
    display: flex;
    gap: var(--spacing-8);
    overflow-x: auto;
    scrollbar-width: none;
  }

  :global(.discovery-categories::-webkit-scrollbar) {
    display: none;
  }

  :global(.discovery-categories button) {
    min-height: 38px;
    padding: 0 var(--spacing-16);
    flex: 0 0 auto;
    border: 0;
    border-radius: var(--radius-tag);
    color: var(--color-charcoal);
    background: var(--color-fog-canvas);
    cursor: pointer;
  }

  :global(.discovery-categories button[aria-pressed="true"]) {
    color: var(--color-pure-white);
    background: var(--color-apple-ink);
  }

  :global(.discovery-sort) {
    display: grid;
    grid-template-columns: repeat(2, 68px);
    border-radius: var(--radius-button);
    overflow: hidden;
    background: var(--color-fog-canvas);
  }

  :global(.discovery-sort button) {
    min-height: 38px;
    padding: 0;
    border: 0;
    color: var(--color-graphite);
    background: transparent;
    cursor: pointer;
  }

  :global(.discovery-sort button[aria-pressed="true"]) {
    color: var(--color-pure-white);
    background: var(--color-apple-ink);
  }

  :global(.discovery-results-heading) {
    min-height: 116px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--spacing-24);
    padding-bottom: var(--spacing-24);
  }

  :global(.discovery-results-heading h2) {
    margin-bottom: 0;
    font-size: var(--text-heading-sm);
    letter-spacing: var(--tracking-heading-sm);
  }

  :global(.discovery-results-heading [role="status"]) {
    color: var(--color-slate);
    font-size: var(--text-caption);
    white-space: nowrap;
  }

  :global(.discovery-grid) {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--spacing-52) var(--spacing-28);
  }

  :global(.discovery-card),
  :global(.discovery-card a) {
    min-width: 0;
  }

  :global(.discovery-card a) {
    display: grid;
    align-content: start;
  }

  :global(.discovery-card a:hover h3) {
    color: var(--color-link-blue);
  }

  :global(.discovery-card img) {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 10;
    display: block;
    border-radius: var(--radius-image);
    object-fit: cover;
  }

  :global(.discovery-card__body) {
    min-width: 0;
    padding: var(--spacing-20) var(--spacing-4) 0;
  }

  :global(.discovery-card__meta) {
    min-height: 20px;
    margin-bottom: var(--spacing-12);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-12);
    color: var(--color-slate);
    font-size: var(--text-caption);
  }

  :global(.discovery-card__meta span) {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  :global(.discovery-card h3) {
    margin-bottom: var(--spacing-12);
    overflow-wrap: anywhere;
    font-size: 26px;
    font-weight: var(--font-weight-medium);
    line-height: 1.25;
    letter-spacing: var(--tracking-subheading);
  }

  :global(.discovery-card p) {
    margin-bottom: 0;
    color: var(--color-graphite);
    font-size: var(--text-body-sm);
    line-height: 1.58;
    letter-spacing: var(--tracking-body-sm);
  }

  :global(.discovery-empty) {
    min-height: 360px;
    padding-block: var(--spacing-80);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  :global(.discovery-empty h2) {
    margin-bottom: var(--spacing-12);
    font-size: var(--text-subheading);
  }

  :global(.discovery-empty p) {
    margin-bottom: var(--spacing-24);
    color: var(--color-graphite);
  }

  :global(.section-heading p) {
    margin-bottom: var(--spacing-8);
    color: var(--color-link-blue);
    font-size: var(--text-caption);
    font-weight: var(--font-weight-semibold);
  }

  :global(.section-heading h2) {
    margin-bottom: 0;
    color: var(--color-apple-ink);
    font-size: var(--text-heading-sm);
    font-weight: var(--font-weight-medium);
    letter-spacing: var(--tracking-heading-sm);
  }

  :global(.track-intro) {
    padding-block: var(--spacing-76) var(--spacing-52);
  }

  :global(.track-grid) {
    margin-top: var(--spacing-28);
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border-block: 1px solid var(--color-divider);
  }

  :global(.track-grid button) {
    min-width: 0;
    min-height: 172px;
    padding: var(--spacing-24);
    display: grid;
    grid-template-rows: auto auto 1fr;
    align-content: start;
    gap: var(--spacing-12);
    border: 0;
    border-right: 1px solid var(--color-divider);
    color: var(--color-apple-ink);
    background: transparent;
    cursor: pointer;
    text-align: left;
    transition: background-color 180ms ease, color 180ms ease;
  }

  :global(.track-grid button:last-child) {
    border-right: 0;
  }

  :global(.track-grid button:hover) {
    background: var(--color-fog-canvas);
  }

  :global(.track-grid button[aria-pressed="true"]) {
    color: var(--color-pure-white);
    background: var(--color-apple-ink);
  }

  :global(.track-grid button > span) {
    color: var(--color-link-blue);
    font-size: var(--text-caption);
    font-weight: var(--font-weight-semibold);
  }

  :global(.track-grid button[aria-pressed="true"] > span),
  :global(.track-grid button[aria-pressed="true"] small) {
    color: var(--color-ash);
  }

  :global(.track-grid strong) {
    font-size: var(--text-subheading);
    font-weight: var(--font-weight-semibold);
  }

  :global(.track-grid small) {
    color: var(--color-graphite);
    font-size: var(--text-body-sm);
    line-height: var(--leading-body-sm);
  }

  :global(.starter-picker) {
    position: relative;
    isolation: isolate;
    margin-bottom: var(--spacing-76);
    padding: var(--spacing-56) var(--spacing-40) var(--spacing-48);
    overflow: hidden;
    border: 1px solid var(--color-glass-border);
    border-radius: var(--radius-panel);
    background: var(--color-fog-canvas);
    background: var(--color-glass-surface);
    -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(145%);
    backdrop-filter: blur(var(--glass-blur)) saturate(145%);
    animation: glass-settle var(--motion-enter) var(--motion-apple) both;
  }

  :global(.starter-picker__heading) {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(240px, 0.56fr);
    align-items: end;
    gap: var(--spacing-48);
  }

  :global(.starter-picker__heading h2) {
    font-weight: var(--font-weight-medium);
    line-height: 1.22;
  }

  :global(.starter-picker__heading > p) {
    margin-bottom: var(--spacing-4);
    color: var(--color-graphite);
    font-size: var(--text-body-sm);
    line-height: var(--leading-body-sm);
  }

  :global(.starter-picker__controls) {
    margin-top: var(--spacing-40);
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--spacing-32);
  }

  :global(.preference-group) {
    min-width: 0;
    margin: 0;
    padding: 0;
    border: 0;
  }

  :global(.preference-group legend) {
    margin-bottom: var(--spacing-16);
    color: var(--color-graphite);
    font-size: var(--text-caption);
    font-weight: var(--font-weight-medium);
  }

  :global(.preference-group > div) {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-8);
  }

  :global(.preference-group button) {
    min-height: 38px;
    padding: 0 var(--spacing-16);
    flex: 0 0 auto;
    border: 1px solid var(--color-glass-border);
    border-radius: var(--radius-tag);
    color: var(--color-charcoal);
    background: var(--color-glass-control);
    cursor: pointer;
    font-size: var(--text-caption);
    transition:
      color var(--motion-fast) ease,
      background-color var(--motion-fast) ease,
      border-color var(--motion-fast) ease,
      transform var(--motion-fast) var(--motion-apple);
  }

  :global(.preference-group button:hover) {
    border-color: rgba(29, 29, 31, 0.32);
    background: rgba(255, 255, 255, 0.92);
    transform: translateY(-1px);
  }

  :global(.preference-group button[aria-pressed="true"]) {
    border-color: var(--color-apple-ink);
    color: var(--color-pure-white);
    background: var(--color-apple-ink);
  }

  :global(.preference-group button[aria-pressed="true"]:hover) {
    background: var(--color-apple-ink);
  }

  :global(.starter-results) {
    margin-top: var(--spacing-48);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-top: 1px solid var(--color-glass-border);
  }

  :global(.starter-result) {
    min-width: 0;
    padding: var(--spacing-28) var(--spacing-24) var(--spacing-12);
    display: grid;
    align-content: start;
    gap: var(--spacing-12);
    border-right: 1px solid var(--color-glass-border);
    transition: transform var(--motion-base) var(--motion-apple);
  }

  :global(.starter-result:hover) {
    transform: translateY(-2px);
  }

  :global(.starter-result:last-child) {
    border-right: 0;
  }

  :global(.starter-result__meta) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: var(--color-link-blue);
    font-size: var(--text-caption);
  }

  :global(.starter-result__meta em) {
    color: var(--color-graphite);
    font-style: normal;
  }

  :global(.starter-result h3) {
    height: 54px;
    margin-bottom: 0;
    overflow-wrap: anywhere;
    overflow: hidden;
    font-size: 20px;
    font-weight: var(--font-weight-medium);
    line-height: 1.35;
  }

  :global(.starter-result h3 a) {
    height: 54px;
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  :global(.starter-result > p) {
    min-height: 82px;
    margin-bottom: 0;
    display: -webkit-box;
    overflow-wrap: anywhere;
    color: var(--color-graphite);
    font-size: var(--text-body-sm);
    line-height: 1.58;
  }

  :global(.starter-result__takeaway) {
    min-height: 104px;
    padding-left: var(--spacing-12);
    display: grid;
    align-content: start;
    gap: var(--spacing-8);
    border-left: 2px solid var(--color-link-blue);
    overflow-wrap: anywhere;
  }

  :global(.starter-result__takeaway span) {
    color: var(--color-link-blue);
    font-size: var(--text-caption);
  }

  :global(.starter-result__takeaway strong) {
    font-size: var(--text-body-sm);
    font-weight: var(--font-weight-medium);
    line-height: var(--leading-body-sm);
  }

  :global(.text-link) {
    width: fit-content;
    color: var(--color-link-blue);
    font-size: var(--text-body-sm);
    transition: opacity var(--motion-fast) ease, transform var(--motion-fast) var(--motion-apple);
  }

  :global(.text-link:hover) {
    opacity: 0.72;
    transform: translateX(2px);
  }

  :global(.discovery-controls) {
    min-height: 124px;
  }

  :global(.discovery-grid) {
    gap: var(--spacing-28);
  }

  :global(.discovery-card) {
    min-width: 0;
    display: grid;
    grid-template-rows: auto 1fr;
    overflow: hidden;
    border: 1px solid var(--color-divider);
    border-radius: 8px;
    background: var(--color-pure-white);
  }

  :global(.discovery-card__visual) {
    min-width: 0;
    display: block;
    overflow: hidden;
    background: var(--color-fog-canvas);
  }

  :global(.discovery-card__visual img) {
    border-radius: 0;
    transition: transform 240ms ease;
  }

  :global(.discovery-card__visual:hover img) {
    transform: scale(1.018);
  }

  :global(.discovery-card__body) {
    padding: var(--spacing-20);
    display: flex;
    flex-direction: column;
  }

  :global(.discovery-card__meta) {
    margin-bottom: var(--spacing-12);
  }

  :global(.discovery-card__meta span:first-child) {
    color: var(--color-link-blue);
    font-weight: var(--font-weight-semibold);
  }

  :global(.discovery-card h3 a:hover) {
    color: var(--color-link-blue);
  }

  :global(.discovery-card__reason) {
    margin-bottom: var(--spacing-16) !important;
  }

  :global(.discovery-card__takeaway) {
    margin-bottom: var(--spacing-16);
    padding: var(--spacing-12) 0 var(--spacing-12) var(--spacing-12);
    border-left: 2px solid var(--color-link-blue);
    background: var(--color-fog-canvas);
  }

  :global(.discovery-card__takeaway span) {
    display: block;
    margin-bottom: var(--spacing-8);
    color: var(--color-link-blue);
    font-size: var(--text-caption);
    font-weight: var(--font-weight-semibold);
  }

  :global(.discovery-card__takeaway p) {
    color: var(--color-apple-ink);
    font-weight: var(--font-weight-medium);
  }

  :global(.discovery-card__tags) {
    margin-bottom: var(--spacing-20);
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-8);
  }

  :global(.discovery-card__tags span) {
    padding: var(--spacing-4) var(--spacing-8);
    border-radius: var(--radius-tag);
    color: var(--color-graphite);
    background: var(--color-fog-canvas);
    font-size: var(--text-caption);
  }

  :global(.discovery-card__actions) {
    margin-top: auto;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--spacing-8);
  }

  :global(.discovery-card__actions .button-primary),
  :global(.discovery-card__actions button) {
    min-width: 0;
    min-height: 44px;
    padding: 0 var(--spacing-12);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-button);
    cursor: pointer;
    font-size: var(--text-caption);
    font-weight: var(--font-weight-medium);
    text-align: center;
  }

  :global(.discovery-card__actions button) {
    border: 1px solid var(--color-divider);
    color: var(--color-apple-ink);
    background: var(--color-pure-white);
  }

  :global(.discovery-card__actions button:hover) {
    border-color: var(--color-apple-ink);
  }

  @media (max-width: 1180px) {
    .discover-hero__inner {
      grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    }

    .spotlight__copy {
      right: var(--spacing-8);
    }

    :global(.starter-picker__controls) {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 960px) {
    .discover-hero,
    .discover-hero__inner {
      min-height: auto;
    }

    .discover-hero__inner {
      padding-block: var(--spacing-76);
      grid-template-columns: 1fr;
      gap: var(--spacing-40);
    }

    .discover-hero__copy {
      padding-block: 0;
    }

    .spotlight {
      min-height: 430px;
    }

    .spotlight__visual {
      width: min(78%, 680px);
    }

    :global(.discovery-grid) {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    :global(.track-grid) {
