---
import { DiscoveryExplorer } from "../components/DiscoveryExplorer";
import BaseLayout from "../layouts/BaseLayout.astro";
import { publicDataset } from "../lib/public-dataset";

const { items } = publicDataset;
const featuredItem = items.find((item) => item.featured) ?? items[0];
---

<BaseLayout
  title="发现 | AI Work Discovery"
  description="发现 AI 工作灵感、协作方式、案例和工具。"
>
  <section class="discover-hero" aria-labelledby="discover-title">
    <div class="discover-hero__inner container">
      <div class="discover-hero__copy">
        <p class="discover-hero__eyebrow">工作发现</p>
        <h1 id="discover-title"><span>找到下一项值得尝试的</span><br /><span>AI 工作方法</span></h1>
        <p class="discover-hero__summary">
          探索真实可复用的实践，快速应用到你的团队与工作流。
        </p>
        <div class="discover-hero__actions">
          <a class="button-primary" href={`/content/${featuredItem.slug}`}>浏览本周精选</a>
          <a class="discover-hero__link" href="/discover#discovery-results-title">查看全部</a>
        </div>
      </div>

      <div class="spotlight" aria-label="本周精选内容">
        <a class="spotlight__visual" href={`/content/${featuredItem.slug}`}>
          <img
            src={featuredItem.coverImage}
            alt={`${featuredItem.title}内容预览`}
            width="960"
            height="600"
            fetchpriority="high"
          />
        </a>
        <div class="spotlight__copy">
          <p>本周精选</p>
          <h2>{featuredItem.title.replace(/^用飞书桥/, "")}</h2>
          <a href={`/content/${featuredItem.slug}`}>阅读内容</a>
        </div>
      </div>
    </div>
  </section>

  <div class="discover-content">
    <div class="container">
      <DiscoveryExplorer client:load items={items} />
    </div>
  </div>
</BaseLayout>

<style>
  .discover-hero {
    min-height: 620px;
    overflow: hidden;
    background-color: var(--color-fog-canvas);
    background-image: url("/images/hero-glass-rings.webp");
    background-position: center;
    background-size: cover;
  }

  .discover-hero__inner {
    min-height: 620px;
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    align-items: center;
    gap: var(--spacing-40);
  }

  .discover-hero__copy {
    position: relative;
    z-index: 2;
    align-self: center;
    padding-block: var(--spacing-80);
  }

  .discover-hero__eyebrow {
    margin-bottom: var(--spacing-24);
    color: var(--color-graphite);
    font-size: var(--text-body-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--tracking-body-sm);
  }

  .discover-hero h1 {
    max-width: 620px;
    margin-bottom: var(--spacing-24);
    color: var(--color-apple-ink);
    font-size: clamp(52px, 4vw, 64px);
    font-weight: var(--font-weight-semibold);
    line-height: var(--leading-heading);
    letter-spacing: var(--tracking-heading-lg);
  }

  .discover-hero__summary {
    max-width: 500px;
    margin-bottom: var(--spacing-32);
    color: var(--color-graphite);
    font-size: var(--text-body);
    line-height: var(--leading-body);
    letter-spacing: var(--tracking-body);
  }

  .discover-hero__actions {
    display: flex;
    align-items: center;
    gap: var(--spacing-28);
  }

  .discover-hero__actions .button-primary {
    min-height: 48px;
    padding-inline: var(--spacing-24);
    font-size: var(--text-body-sm);
  }

  .discover-hero__link,
  .spotlight__copy a {
    color: var(--color-link-blue);
    font-size: var(--text-body-sm);
  }

  .discover-hero__link:hover,
  .spotlight__copy a:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .spotlight {
    position: relative;
    min-width: 0;
    min-height: 520px;
    display: flex;
    align-items: center;
  }

  .spotlight__visual {
    width: min(70%, 760px);
    min-width: 0;
    display: block;
    transform: translateX(2%);
    transition: transform 350ms ease;
  }

  .spotlight__visual:hover {
    transform: translateX(2%) scale(1.012);
  }

  .spotlight__visual img {
    width: 100%;
    height: auto;
    max-width: 100%;
    aspect-ratio: 16 / 10;
    display: block;
    border-radius: var(--radius-image);
    object-fit: cover;
    object-position: top;
  }

  .spotlight__copy {
    position: absolute;
    right: 0;
    bottom: var(--spacing-48);
    width: min(240px, 24%);
  }

  .spotlight__copy p {
    margin-bottom: var(--spacing-12);
    color: var(--color-graphite);
    font-size: var(--text-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--tracking-caption);
  }

  .spotlight__copy h2 {
    margin-bottom: var(--spacing-16);
    color: var(--color-apple-ink);
    font-size: var(--text-subheading);
    line-height: var(--leading-subheading);
    letter-spacing: var(--tracking-subheading);
  }

  .discover-content {
    padding-block: var(--spacing-32) var(--spacing-100);
    background: var(--color-pure-white);
  }

  :global(.discovery-explorer) {
    min-width: 0;
  }

  :global(.discovery-controls) {
    min-width: 0;
    min-height: 124px;
    display: grid;
    align-content: start;
    gap: var(--spacing-16);
  }

  :global(.discovery-search) {
    position: relative;
    display: block;
  }

  :global(.discovery-search input) {
    width: 100%;
    min-height: 52px;
    padding: 0 var(--spacing-20) 0 var(--spacing-48);
    border: 0;
    border-radius: var(--radius-button);
    color: var(--color-apple-ink);
    background: var(--color-fog-canvas);
    font-size: var(--text-body-sm);
  }

  :global(.discovery-search input::placeholder) {
    color: var(--color-slate);
  }

  :global(.discovery-search__icon) {
    position: absolute;
    top: 50%;
    left: var(--spacing-20);
    z-index: 1;
    width: 14px;
    height: 14px;
    border: 1.5px solid var(--color-graphite);
    border-radius: 50%;
    pointer-events: none;
    transform: translateY(-55%);
  }

  :global(.discovery-search__icon::after) {
    position: absolute;
    right: -5px;
    bottom: -3px;
    width: 6px;
    height: 1.5px;
    background: var(--color-graphite);
    content: "";
    transform: rotate(45deg);
    transform-origin: left center;
  }

  :global(.discovery-filter-row) {
    min-width: 0;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: var(--spacing-24);
  }

  :global(.discovery-categories) {
    min-width: 0;
    display: flex;
    gap: var(--spacing-8);
    overflow-x: auto;
    scrollbar-width: none;
  }

  :global(.discovery-categories::-webkit-scrollbar) {
    display: none;
  }

  :global(.discovery-categories button) {
    min-height: 38px;
    padding: 0 var(--spacing-16);
    flex: 0 0 auto;
    border: 0;
    border-radius: var(--radius-tag);
    color: var(--color-charcoal);
    background: var(--color-fog-canvas);
    cursor: pointer;
  }

  :global(.discovery-categories button[aria-pressed="true"]) {
    color: var(--color-pure-white);
    background: var(--color-apple-ink);
  }

  :global(.discovery-sort) {
    display: grid;
    grid-template-columns: repeat(2, 68px);
    border-radius: var(--radius-button);
    overflow: hidden;
    background: var(--color-fog-canvas);
  }

  :global(.discovery-sort button) {
    min-height: 38px;
    padding: 0;
    border: 0;
    color: var(--color-graphite);
    background: transparent;
    cursor: pointer;
  }

  :global(.discovery-sort button[aria-pressed="true"]) {
    color: var(--color-pure-white);
    background: var(--color-apple-ink);
  }

  :global(.discovery-results-heading) {
    min-height: 116px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--spacing-24);
    padding-bottom: var(--spacing-24);
  }

  :global(.discovery-results-heading h2) {
    margin-bottom: 0;
    font-size: var(--text-heading-sm);
    letter-spacing: var(--tracking-heading-sm);
  }

  :global(.discovery-results-heading [role="status"]) {
    color: var(--color-slate);
    font-size: var(--text-caption);
    white-space: nowrap;
  }

  :global(.discovery-grid) {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--spacing-52) var(--spacing-28);
  }

  :global(.discovery-card),
  :global(.discovery-card a) {
    min-width: 0;
  }

  :global(.discovery-card a) {
    display: grid;
    align-content: start;
  }

  :global(.discovery-card a:hover h3) {
    color: var(--color-link-blue);
  }

  :global(.discovery-card img) {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 10;
    display: block;
    border-radius: var(--radius-image);
    object-fit: cover;
  }

  :global(.discovery-card__body) {
    min-width: 0;
    padding: var(--spacing-20) var(--spacing-4) 0;
  }

  :global(.discovery-card__meta) {
    min-height: 20px;
    margin-bottom: var(--spacing-12);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-12);
    color: var(--color-slate);
    font-size: var(--text-caption);
  }

  :global(.discovery-card__meta span) {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  :global(.discovery-card h3) {
    margin-bottom: var(--spacing-12);
    overflow-wrap: anywhere;
    font-size: var(--text-subheading);
    line-height: var(--leading-subheading);
    letter-spacing: var(--tracking-subheading);
  }

  :global(.discovery-card p) {
    margin-bottom: 0;
    color: var(--color-graphite);
    font-size: var(--text-body-sm);
    line-height: var(--leading-body-sm);
    letter-spacing: var(--tracking-body-sm);
  }

  :global(.discovery-empty) {
    min-height: 360px;
    padding-block: var(--spacing-80);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  :global(.discovery-empty h2) {
    margin-bottom: var(--spacing-12);
    font-size: var(--text-subheading);
  }

  :global(.discovery-empty p) {
    margin-bottom: var(--spacing-24);
    color: var(--color-graphite);
  }

  @media (max-width: 1180px) {
    .discover-hero__inner {
      grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    }

    .spotlight__copy {
      right: var(--spacing-8);
    }
  }

  @media (max-width: 960px) {
    .discover-hero,
    .discover-hero__inner {
      min-height: auto;
    }

    .discover-hero__inner {
      padding-block: var(--spacing-76);
      grid-template-columns: 1fr;
      gap: var(--spacing-40);
    }

    .discover-hero__copy {
      padding-block: 0;
    }

    .spotlight {
      min-height: 430px;
    }

    .spotlight__visual {
      width: min(78%, 680px);
    }

    :global(.discovery-grid) {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .discover-hero {
      background-position: 62% center;
    }

    .discover-hero__inner {
      padding-block: var(--spacing-32);
      gap: var(--spacing-24);
    }

    .discover-hero__eyebrow {
      margin-bottom: var(--spacing-12);
      font-size: 15px;
    }

    .discover-hero h1 {
      margin-bottom: var(--spacing-16);
      font-size: 35px;
      letter-spacing: -0.2px;
    }

    .discover-hero__summary {
      margin-bottom: var(--spacing-24);
      font-size: var(--text-body-sm);
    }

    .discover-hero__actions {
      align-items: center;
      flex-direction: row;
      gap: var(--spacing-20);
    }

    .spotlight {
      min-height: auto;
      display: grid;
      gap: var(--spacing-16);
    }

    .spotlight__visual {
      width: 100%;
      transform: none;
    }

    .spotlight__visual:hover {
      transform: scale(1.006);
    }

    .spotlight__copy {
      position: static;
      width: 100%;
    }

    .spotlight__copy h2 {
      max-width: 320px;
      margin-bottom: var(--spacing-12);
      font-size: 24px;
    }

    .discover-content {
      padding-block: var(--spacing-24) var(--spacing-80);
    }

    :global(.discovery-controls) {
      min-height: 176px;
    }

    :global(.discovery-filter-row) {
      grid-template-columns: 1fr;
      gap: var(--spacing-12);
    }

    :global(.discovery-sort) {
      width: 100%;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    :global(.discovery-results-heading) {
      min-height: 96px;
    }

    :global(.discovery-results-heading h2) {
      font-size: var(--text-subheading);
    }

    :global(.discovery-grid) {
      grid-template-columns: 1fr;
      gap: var(--spacing-48);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .spotlight__visual {
      transition: none;
    }
  }

  @media (min-width: 1181px) {
    .discover-hero h1 span {
      white-space: nowrap;
    }
  }

  @media (min-width: 380px) and (max-width: 720px) {
    .discover-hero h1 span {
      white-space: nowrap;
    }
  }
</style>
